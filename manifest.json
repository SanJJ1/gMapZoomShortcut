{
    "manifest_version": 3,
    "name": "Google Maps Keyboard Nav",
    "version": "1.2",
    "description": "Fixes Google Maps keyboard shortcuts. Reliable +/- zoom and HJKL vim-style panning with smooth acceleration.",
    "icons": {
        "128": "logo.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.google.com/maps*"
            ],
            "js": [
                "content.js"
            ],
            "world": "MAIN",
            "run_at": "document_idle"
        }
    ]
}
